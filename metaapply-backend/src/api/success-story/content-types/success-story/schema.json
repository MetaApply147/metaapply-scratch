{
  "kind": "collectionType",
  "collectionName": "success_stories",
  "info": {
    "singularName": "success-story",
    "pluralName": "success-stories",
    "displayName": "Success Story"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "success-story.video-story",
        "success-story.testimonial-story"
      ]
    },
    "page": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "home",
        "metafly",
        "metafinance",
        "metastay",
        "metainsure"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "video",
        "testimonial"
      ]
    },
    "ctaText": {
      "type": "string"
    },
    "ctaUrl": {
      "type": "string"
    }
  }
}
