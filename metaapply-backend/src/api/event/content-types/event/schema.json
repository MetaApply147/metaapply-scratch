{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "pageTitle": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "pageTitle"
    },
    "description": {
      "type": "richtext"
    },
    "eventTitle": {
      "type": "string"
    },
    "eventDate": {
      "type": "date"
    },
    "eventDuration": {
      "type": "string"
    },
    "eventLocation": {
      "type": "string"
    },
    "eventRegistrationDetails": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "integer"
    },
    "eventLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "webinarAgenda": {
      "type": "text"
    },
    "registerToday": {
      "type": "text"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "past"
      ]
    },
    "order": {
      "type": "integer"
    },
    "description": {
      "type": "richtext"
    }
  }
}