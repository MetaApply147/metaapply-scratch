{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "date": {
      "type": "date"
    },
    "time": {
      "type": "time"
    },
    "location": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "past"
      ]
    },
    "order": {
      "type": "integer"
    },
    "description": {
      "type": "richtext"
    }
  }
}
